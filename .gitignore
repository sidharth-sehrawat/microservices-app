# ====================================================================
# Terraform
# ====================================================================
# Core terraform directories containing heavy provider binaries
**/.terraform/

# Local state files (can contain plain-text infrastructure secrets)
*.tfstate
*.tfstate.*

# Crash logs
crash.log

# Terraform variables (uncomment if you want to keep your secret tfvars local)
# *.tfvars
# *.tfvars.json

# Override files
override.tf
override.tf.json
_override.tf
_override.tf.json

# ====================================================================
# Helm & Kubernetes (GitOps)
# ====================================================================
# Look up charts dependencies
**/charts/*.tgz
**/charts/charts/

# ====================================================================
# System & IDE Noise
# ====================================================================
.DS_Store
.idea/
.vscode/
*.log
